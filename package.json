{
  "name": "image-generator-workspace",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:windows": "tauri build --bundles nsis,msi",
    "desktop:build:windows:nsis": "tauri build --bundles nsis",
    "desktop:build:windows:msi": "tauri build --bundles msi",
    "desktop:build:macos": "tauri build --bundles app,dmg",
    "desktop:build:macos:app": "tauri build --bundles app",
    "desktop:build:macos:dmg": "tauri build --bundles dmg",
    "desktop:build:linux": "tauri build --bundles appimage,deb,rpm",
    "desktop:build:linux:appimage": "tauri build --bundles appimage",
    "desktop:build:linux:deb": "tauri build --bundles deb",
    "desktop:build:linux:rpm": "tauri build --bundles rpm",
    "release:windows": "powershell -ExecutionPolicy Bypass -File scripts/prepare-windows-release.ps1",
    "version:set": "powershell -ExecutionPolicy Bypass -File scripts/set-version.ps1",
    "signing:windows:import": "powershell -ExecutionPolicy Bypass -File scripts/import-windows-signing-certificate.ps1",
    "signing:windows:configure": "powershell -ExecutionPolicy Bypass -File scripts/configure-windows-signing.ps1",
    "signing:windows:verify": "powershell -ExecutionPolicy Bypass -File scripts/verify-windows-signature.ps1",
    "tauri": "tauri",
    "clean:install": "powershell -ExecutionPolicy Bypass -File scripts/clean-install.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
